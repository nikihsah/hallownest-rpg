<div class="item-catalog-root">
  <div class="item-catalog-controls">
    <input type="search" data-item-search placeholder="{{localize 'HRPG.ItemSearch'}}" autocomplete="off">
    <button type="button" data-action="create-custom-item">{{localize "HRPG.CreateCustomItem"}}</button>
  </div>
  <div class="item-catalog-content">
    {{#each groups as |group|}}
      <section class="item-category" data-item-category="{{group.key}}">
        <h2>{{localize group.label}}</h2>
        <div class="item-catalog-grid">
          {{#each group.items as |item|}}
            <article class="item-choice {{#if item.owned}}owned{{/if}} {{#unless item.available}}unavailable{{/unless}}" data-item-source-id="{{item.sourceId}}">
              <header>
                <h3>{{item.name}}</h3>
                <span>{{localize item.typeLabel}}</span>
              </header>
              {{#if item.typeName}}<small>{{localize item.typeName}}</small>{{/if}}
              {{#if item.meta}}<small>{{item.meta}}</small>{{/if}}
              {{#if item.warning}}<small class="item-choice-warning">{{localize item.warning}}</small>{{/if}}
              {{#if item.description}}<p>{{item.description}}</p>{{/if}}
              {{#if item.rawText}}
                <details>
                  <summary>{{localize "HRPG.ItemRawText"}}</summary>
                  <p>{{item.rawText}}</p>
                </details>
              {{/if}}
              <button type="button" data-action="add-catalog-item">{{localize "HRPG.AddItem"}}</button>
            </article>
          {{/each}}
        </div>
      </section>
    {{/each}}
  </div>
</div>
