<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header hk-frame">
    <img class="profile-img" src="{{actor.img}}" data-action="choose-portrait" data-actor-portrait role="button" tabindex="0" title="{{actor.name}}">
    <div class="header-fields">
      <div class="identity-row">
        <input class="name" name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'HRPG.Name'}}">
        {{#if system.creation.templateApplied}}
          <label class="milestone-field">{{localize "HRPG.Milestone"}}
            <select name="system.advancement.milestone" data-milestone-select data-current-milestone="{{system.advancement.milestone}}" data-tooltip="{{milestoneTooltip}}" data-tooltip-direction="DOWN">
              {{#each milestoneOptions as |milestone|}}<option value="{{milestone.value}}" title="{{milestone.hint}}" {{#if milestone.selected}}selected{{/if}}>{{milestone.value}}</option>{{/each}}
            </select>
          </label>
          <button class="rest-button" type="button" data-action="rest">{{localize "HRPG.Rest"}}</button>
        {{/if}}
      </div>
      {{#if system.creation.templateApplied}}
        <div class="resource-row">
          <section class="core-resource-table">
            <h2>{{localize "HRPG.ResourceHeart"}}</h2>
            <label>{{localize "HRPG.ResourceMaxShort"}}<output title="{{localize 'HRPG.ResourceMax'}}">{{system.effective.resources.heart.max}}</output></label>
            <label>{{localize "HRPG.CurrentValueShort"}}<input name="system.resources.heart.value" type="number" value="{{system.resources.heart.value}}" title="{{localize 'HRPG.CurrentValue'}}"></label>
            <label>{{localize "HRPG.TempHitPointsShort"}}<input name="system.resources.heart.temp" type="number" value="{{system.resources.heart.temp}}" title="{{localize 'HRPG.TempHitPoints'}}"></label>
          </section>
          <section class="core-resource-table">
            <h2>{{localize "HRPG.ResourceSoul"}}</h2>
            <label>{{localize "HRPG.ResourceMaxShort"}}<output title="{{localize 'HRPG.ResourceMax'}}">{{system.effective.resources.soul.max}}</output></label>
            <label>{{localize "HRPG.CurrentValueShort"}}<input name="system.resources.soul.value" type="number" value="{{system.resources.soul.value}}" title="{{localize 'HRPG.CurrentValue'}}"></label>
            <label>{{localize "HRPG.TempHitPointsShort"}}<input name="system.resources.soul.temp" type="number" value="{{system.resources.soul.temp}}" title="{{localize 'HRPG.TempHitPoints'}}"></label>
          </section>
          <section class="core-resource-table">
            <h2>{{localize "HRPG.ResourceStamina"}}</h2>
            <label>{{localize "HRPG.ResourceMaxShort"}}<output title="{{localize 'HRPG.ResourceMax'}}">{{system.effective.resources.stamina.max}}</output></label>
            <label>{{localize "HRPG.CurrentValueShort"}}<input name="system.resources.stamina.value" type="number" value="{{system.resources.stamina.value}}" title="{{localize 'HRPG.CurrentValue'}}"></label>
            <label>{{localize "HRPG.TempHitPointsShort"}}<input name="system.resources.stamina.temp" type="number" value="{{system.resources.stamina.temp}}" title="{{localize 'HRPG.TempHitPoints'}}"></label>
          </section>
          <label>{{localize "HRPG.ResourceSatiety"}}<span><input name="system.resources.satiety.value" type="number" value="{{system.resources.satiety.value}}"><b>/</b><output>{{system.resources.satiety.max}}</output></span></label>
        </div>
      {{/if}}
    </div>
  </header>

  {{#unless system.creation.templateApplied}}
    <section class="creation-gate hk-frame">
      <span class="gate-kicker">{{localize "HRPG.CharacterCreation"}}</span>
      <h2>{{localize "HRPG.ChooseBugTemplate"}}</h2>
      <p>{{localize "HRPG.ChooseBugTemplateHint"}}</p>
      <label>{{localize "HRPG.BugType"}}
        <select name="system.secondary.size" data-template-size>{{selectOptions config.sizes selected=system.secondary.size localize=true}}</select>
      </label>
      <button type="button" data-action="apply-size">{{localize "HRPG.ApplySize"}}</button>
    </section>
  {{else}}
    <nav class="sheet-tabs tabs" data-group="primary">
      <a class="item active" data-action="select-tab" data-tab="overview">{{localize "HRPG.Overview"}}</a>
      <a class="item" data-action="select-tab" data-tab="traits">{{localize "HRPG.Traits"}}</a>
      <a class="item" data-action="select-tab" data-tab="charms">{{localize "HRPG.Charms"}}</a>
      <a class="item" data-action="select-tab" data-tab="techniques">{{localize "HRPG.Techniques"}}</a>
      {{#unless isMasterBug}}<a class="item" data-action="select-tab" data-tab="skills">{{localize "HRPG.Skills"}}</a>{{/unless}}
      <a class="item" data-action="select-tab" data-tab="inventory">{{localize "HRPG.Inventory"}}</a>
      <a class="item" data-action="select-tab" data-tab="notes">{{localize "HRPG.Notes"}}</a>
    </nav>

    <section class="sheet-body">
      <div class="tab overview active" data-group="primary" data-tab="overview">
        <div class="overview-grid">
          <section class="panel attributes-panel">
            <h2>{{localize "HRPG.Attributes"}}</h2>
            <div class="attribute-grid">
              {{#each attributeRows as |attribute|}}
                <button type="button" data-action="roll-attribute" data-attribute="{{attribute.key}}" data-tooltip="{{attribute.breakdown}}" data-tooltip-direction="UP">
                  <span>{{localize attribute.label}}</span><strong>{{attribute.maximum}}</strong>
                </button>
                <input data-current-attribute="{{attribute.key}}" type="number" step="0.5" value="{{attribute.current}}" title="{{localize 'HRPG.CurrentAttribute'}}">
              {{/each}}
            </div>
          </section>

          <section class="panel secondary-panel">
            <div class="panel-heading"><h2>{{localize "HRPG.Secondary"}}</h2><span>{{localize (lookup config.sizes system.secondary.size)}}</span></div>
            <div class="load-summary {{#if loadSummary.over}}overloaded{{/if}}" data-tooltip="{{loadSummary.tooltip}}" data-tooltip-direction="UP">
              <span>{{localize "HRPG.CarriedWeight"}}</span>
              <strong>{{loadSummary.current}} / {{loadSummary.maximum}}</strong>
              {{#if loadSummary.over}}<small>{{localize "HRPG.LoadOverage"}} {{loadSummary.overage}}</small>{{else}}<small>{{localize "HRPG.LoadMaximum"}}</small>{{/if}}
            </div>
            <div class="resource-stat-grid">
              <div class="resource-stat-card custom-resource-stat">
                <input name="system.resources.custom1.label" type="text" value="{{system.resources.custom1.label}}" placeholder="{{localize 'HRPG.CustomResource'}}">
                <label>{{localize "HRPG.ResourceMax"}}<input name="system.resources.custom1.max" type="number" value="{{system.resources.custom1.max}}"></label>
                <label>{{localize "HRPG.CurrentValue"}}<input name="system.resources.custom1.value" type="number" value="{{system.resources.custom1.value}}"></label>
              </div>
              <div class="resource-stat-card custom-resource-stat">
                <input name="system.resources.custom2.label" type="text" value="{{system.resources.custom2.label}}" placeholder="{{localize 'HRPG.CustomResource'}}">
                <label>{{localize "HRPG.ResourceMax"}}<input name="system.resources.custom2.max" type="number" value="{{system.resources.custom2.max}}"></label>
                <label>{{localize "HRPG.CurrentValue"}}<input name="system.resources.custom2.value" type="number" value="{{system.resources.custom2.value}}"></label>
              </div>
              <div class="resource-stat-card custom-resource-stat">
                <input name="system.resources.custom3.label" type="text" value="{{system.resources.custom3.label}}" placeholder="{{localize 'HRPG.CustomResource'}}">
                <label>{{localize "HRPG.ResourceMax"}}<input name="system.resources.custom3.max" type="number" value="{{system.resources.custom3.max}}"></label>
                <label>{{localize "HRPG.CurrentValue"}}<input name="system.resources.custom3.value" type="number" value="{{system.resources.custom3.value}}"></label>
              </div>
            </div>
            <div class="stat-grid">
              {{#each secondaryRows as |stat|}}
                <div class="stat-card" data-tooltip="{{stat.tooltip}}" data-tooltip-direction="UP">
                  {{#if stat.rollable}}<button type="button" data-action="roll-secondary" data-secondary="{{stat.key}}">{{localize stat.label}}</button>{{else}}<span>{{localize stat.label}}</span>{{/if}}
                  <output title="{{localize 'HRPG.PermanentValue'}}">{{stat.permanent}}</output>
                  <input data-current-secondary="{{stat.key}}" data-permanent="{{stat.permanent}}" type="number" step="0.5" value="{{stat.current}}" title="{{localize 'HRPG.CurrentValue'}}">
                </div>
              {{/each}}
            </div>
          </section>

          <section class="panel paths-panel">
            <div class="panel-heading"><h2>{{localize "HRPG.Paths"}}</h2><button type="button" data-action="create-item" data-type="path" data-tooltip="{{localize 'HRPG.CreateCustomPath'}}">+</button></div>
            <div class="path-picker">
              <select data-path-select aria-label="{{localize 'HRPG.ChoosePath'}}">
                <option value="">{{localize "HRPG.ChoosePath"}}</option>
                {{#each pathCatalog as |path|}}<option value="{{path.sourceId}}" {{#if path.disabled}}disabled{{/if}}>{{path.name}} - {{localize path.categoryLabel}}</option>{{/each}}
              </select>
              <button type="button" data-action="add-path">{{localize "HRPG.AddPath"}}</button>
            </div>
            {{#each itemsByType.path as |path|}}
              <div class="item-row line-item" data-open-item-id="{{path.id}}" role="button" tabindex="0"><img src="{{path.img}}"><span>{{path.name}}</span><small>{{#if (eq path.system.category "mystic")}}{{localize "HRPG.PathMystic"}}{{else}}{{localize "HRPG.PathMartial"}}{{/if}}</small><b>{{path.system.rank}}/{{path.system.rankMax}}</b><button class="item-delete" type="button" data-action="delete-item" data-item-id="{{path.id}}" data-tooltip="{{localize 'HRPG.DeleteItem'}}">&times;</button></div>
            {{else}}<p class="empty-state">{{localize "HRPG.NoPaths"}}</p>{{/each}}
          </section>

          <section class="panel summary-panel">
            <h2>{{localize "HRPG.ShortDescription"}}</h2>
            <textarea name="system.profile.summary" placeholder="{{localize 'HRPG.ShortDescriptionHint'}}">{{system.profile.summary}}</textarea>
          </section>

          <section class="panel status-panel">
            <div class="panel-heading"><h2>{{localize "HRPG.StatusEffects"}}</h2><span>{{localize "HRPG.StatusEffectsHint"}}</span></div>
            <div class="status-picker">
              <select data-status-select aria-label="{{localize 'HRPG.ChooseStatusEffect'}}">
                <option value="">{{localize "HRPG.ChooseStatusEffect"}}</option>
                {{#each statusEffectOptions as |status|}}<option value="{{status.key}}" data-stackable="{{status.stackable}}" data-max="{{status.max}}">{{localize status.label}}</option>{{/each}}
              </select>
              <input data-status-value type="number" min="1" value="1" title="{{localize 'HRPG.StatusEffectValue'}}">
              <button type="button" data-action="apply-status">{{localize "HRPG.ApplyStatusEffect"}}</button>
            </div>
            {{#each activeStatusRows as |status|}}
              <div class="item-row line-item status-row">
                <img src="{{status.img}}">
                <span>{{status.name}}</span>
                <small>{{status.valueLabel}}</small>
                <button class="item-delete" type="button" data-action="remove-status" data-status-key="{{status.key}}" data-tooltip="{{localize 'HRPG.RemoveStatusEffect'}}">&times;</button>
              </div>
            {{else}}<p class="empty-state">{{localize "HRPG.NoStatusEffects"}}</p>{{/each}}
          </section>
        </div>
      </div>

      <div class="tab traits" data-group="primary" data-tab="traits">
        <section class="panel collection-panel">
          <div class="panel-heading"><h2>{{localize "HRPG.Traits"}}</h2><label class="trait-limit">{{localize "HRPG.TraitLimit"}} <span>{{traitCounter.current}} /</span><input name="system.traits.max" type="number" min="0" value="{{traitCounter.max}}"></label><button type="button" data-action="create-item" data-type="trait">+</button></div>
          {{#each traitRows as |trait|}}
            <div class="item-row card-item trait-row" data-open-item-id="{{trait.id}}" role="button" tabindex="0"><img src="{{trait.img}}"><div><strong>{{trait.name}}</strong><small>{{#if (eq trait.system.kind "subtrait")}}{{localize "HRPG.Subtrait"}}{{else}}{{localize "HRPG.Trait"}}{{/if}}</small></div>{{#if trait.qualityEditable}}<label class="trait-quality">{{localize "HRPG.Quality"}} <input data-trait-quality="{{trait.id}}" type="number" min="-1" value="{{trait.qualityValue}}"><span>/</span><input data-trait-quality-max="{{trait.id}}" type="number" min="0" value="{{trait.qualityMax}}"></label>{{/if}}<button class="item-delete" type="button" data-action="delete-item" data-item-id="{{trait.id}}" data-tooltip="{{localize 'HRPG.DeleteItem'}}">&times;</button></div>
          {{else}}<p class="empty-state">{{localize "HRPG.NoTraits"}}</p>{{/each}}
        </section>
      </div>

      <div class="tab charms" data-group="primary" data-tab="charms">
        <section class="panel charm-slots-panel {{#if charmSlots.over}}overloaded{{/if}}" data-tooltip="{{charmSlots.tooltip}}" data-tooltip-direction="UP">
          <h2>{{localize "HRPG.CharmMarks"}}</h2>
          <strong>{{charmSlots.used}} / {{charmSlots.maximum}}</strong>
          <small>{{#if charmSlots.over}}{{localize "HRPG.CharmMarksOver"}} {{charmSlots.overage}}{{else}}{{localize "HRPG.CharmMarksRemaining"}} {{charmSlots.remaining}}{{/if}}</small>
        </section>
        <section class="panel collection-panel">
          <div class="panel-heading"><h2>{{localize "HRPG.Charms"}}</h2><button type="button" data-action="create-item" data-type="charm">+</button></div>
          {{#each charmRows as |item|}}<div class="item-row card-item" data-open-item-id="{{item.id}}" role="button" tabindex="0"><img src="{{item.img}}"><div><strong>{{item.name}}</strong><small>{{#if item.notches}}{{localize "HRPG.Notches"}} {{item.notches}}{{else}}{{localize "HRPG.Notches"}} 0{{/if}}</small></div><label class="item-equipped"><input data-item-equipped="{{item.id}}" type="checkbox" {{#if item.equipped}}checked{{/if}}> {{localize "HRPG.Equipped"}}</label><button class="item-delete" type="button" data-action="delete-item" data-item-id="{{item.id}}" data-tooltip="{{localize 'HRPG.DeleteItem'}}">&times;</button></div>{{else}}<p class="empty-state">{{localize "HRPG.NoCharms"}}</p>{{/each}}
        </section>
      </div>

      <div class="tab techniques" data-group="primary" data-tab="techniques">
        <section class="panel technique-slots-panel {{#if techniqueSlots.over}}overloaded{{/if}}" data-tooltip="{{techniqueSlots.tooltip}}" data-tooltip-direction="UP">
          <h2>{{localize "HRPG.TechniqueSlots"}}</h2>
          <strong>{{techniqueSlots.remaining}} / {{techniqueSlots.maximum}}</strong>
          <small>{{localize "HRPG.TechniqueSlotsRemaining"}}</small>
        </section>
        <div class="split-grid">
          <section class="panel collection-panel">
            <div class="panel-heading"><h2>{{localize "HRPG.ItemArt"}}</h2><button type="button" data-action="create-item" data-type="art">+</button></div>
            {{#each artRows as |item|}}
              <div class="item-row line-item technique-row" data-open-item-id="{{item.id}}" role="button" tabindex="0"><img src="{{item.img}}"><span>{{item.name}}</span><small>{{item.costLabel}}</small><label class="item-equipped"><input data-technique-prepared="{{item.id}}" type="checkbox" {{#if item.prepared}}checked{{/if}}> {{localize "HRPG.Prepared"}}</label><button class="item-delete" type="button" data-action="delete-item" data-item-id="{{item.id}}" data-tooltip="{{localize 'HRPG.DeleteItem'}}">&times;</button></div>
            {{else}}<p class="empty-state">{{localize "HRPG.NoArts"}}</p>{{/each}}
          </section>
          <section class="panel collection-panel">
            <div class="panel-heading"><h2>{{localize "HRPG.ItemSpell"}}</h2><button type="button" data-action="create-item" data-type="spell">+</button></div>
            {{#each spellRows as |item|}}
              <div class="item-row line-item technique-row" data-open-item-id="{{item.id}}" role="button" tabindex="0"><img src="{{item.img}}"><span>{{item.name}}</span><small>{{item.costLabel}}</small><label class="item-equipped"><input data-technique-prepared="{{item.id}}" type="checkbox" {{#if item.prepared}}checked{{/if}}> {{localize "HRPG.Prepared"}}</label><button class="item-delete" type="button" data-action="delete-item" data-item-id="{{item.id}}" data-tooltip="{{localize 'HRPG.DeleteItem'}}">&times;</button></div>
            {{else}}<p class="empty-state">{{localize "HRPG.NoSpells"}}</p>{{/each}}
          </section>
        </div>
      </div>

      {{#unless isMasterBug}}<div class="tab skills" data-group="primary" data-tab="skills">
        <section class="panel collection-panel skill-list-panel">
          <div class="panel-heading"><h2>{{localize "HRPG.Skills"}}</h2><button type="button" data-action="create-item" data-type="skill">+</button></div>
          {{#each skillItemRows as |skill|}}
            <article class="skill-card">
              <header data-open-item-id="{{skill.id}}" role="button" tabindex="0">
                <img src="{{skill.img}}">
                <label class="skill-title-field">{{localize "HRPG.ItemSkill"}}
                  <input type="text" data-skill-item-name="{{skill.id}}" value="{{skill.name}}" placeholder="{{localize 'HRPG.ItemSkill'}}">
                </label>
                <label>{{localize "HRPG.Rank"}}
                  <select data-skill-rank="{{skill.id}}">
                    {{#each skill.rankOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}
                  </select>
                </label>
                <label>{{localize "HRPG.Mastery"}}
                  <select data-skill-mastery="{{skill.id}}">
                    {{#each skill.masteryOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}
                  </select>
                </label>
                <button class="item-delete" type="button" data-action="delete-item" data-item-id="{{skill.id}}" data-tooltip="{{localize 'HRPG.DeleteItem'}}">&times;</button>
              </header>
              <div class="skill-card-rows">
                {{#each skill.rows as |row|}}
                  <div class="skill-edit-row">
                    <input type="text" data-skill-slot="{{../skill.id}}" data-skill-slot-index="{{row.key}}" value="{{row.name}}" placeholder="{{localize 'HRPG.SkillNameHint'}}">
                    <button type="button" data-action="roll-skill" data-skill-name="{{row.name}}" data-tooltip="{{row.breakdown}}" data-tooltip-direction="UP" {{#unless row.name}}disabled{{/unless}}>
                      {{localize "HRPG.Roll"}}
                    </button>
                    <strong>{{row.total}}</strong>
                    {{#if row.mastered}}<em>{{localize "HRPG.MasteryShort"}}</em>{{/if}}
                  </div>
                {{/each}}
              </div>
            </article>
          {{else}}<p class="empty-state">{{localize "HRPG.NoSkills"}}</p>{{/each}}
        </section>
      </div>{{/unless}}

      <div class="tab inventory" data-group="primary" data-tab="inventory">
        {{#each inventoryItemTypes as |label type|}}
          <section class="panel item-group"><div class="panel-heading"><h2>{{localize label}}</h2><button type="button" data-action="create-item" data-type="{{type}}">+</button></div>{{#each (lookup ../itemsByType type) as |item|}}<div class="item-row line-item" data-open-item-id="{{item.id}}" role="button" tabindex="0"><img src="{{item.img}}"><span>{{item.name}}</span><small>{{#if item.system.weightLabel}}{{item.system.weightLabel}}{{else}}{{item.system.weight}}{{/if}}</small><label class="item-equipped"><input data-item-equipped="{{item.id}}" type="checkbox" {{#if item.system.equipped}}checked{{/if}}> {{localize "HRPG.Equipped"}}</label><button class="item-delete" type="button" data-action="delete-item" data-item-id="{{item.id}}" data-tooltip="{{localize 'HRPG.DeleteItem'}}">&times;</button></div>{{else}}<p class="empty-state">{{localize "HRPG.EmptyItemGroup"}}</p>{{/each}}</section>
        {{/each}}
      </div>

      <div class="tab notes" data-group="primary" data-tab="notes">
        <section class="panel notes-panel"><h2>{{localize "HRPG.Notes"}}</h2><textarea name="system.profile.notes">{{system.profile.notes}}</textarea></section>
      </div>
    </section>
  {{/unless}}
</form>
