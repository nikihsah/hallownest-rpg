<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}">
    <div class="header-fields"><input class="name" name="name" type="text" value="{{item.name}}"></div>
  </header>
  <section class="item-properties">
    {{#unless (or (eq item.type "trait") (eq item.type "path"))}}<label>{{localize "HRPG.Quantity"}} <input name="system.quantity" type="number" value="{{system.quantity}}"></label>{{/unless}}
    {{#unless (or (eq item.type "trait") (eq item.type "path"))}}<label>{{localize "HRPG.Weight"}} <input name="system.weight" type="number" step="0.1" value="{{system.weight}}"></label>{{/unless}}
    {{#if (eq item.type "trait")}}
      <label class="checkbox"><input name="system.active" type="checkbox" {{checked system.active}}> {{localize "HRPG.TraitActive"}}</label>
      <label>{{localize "HRPG.TraitKindLabel"}}
        <select name="system.kind">
          <option value="trait" {{#if (eq system.kind "trait")}}selected{{/if}}>{{localize "HRPG.Trait"}}</option>
          <option value="subtrait" {{#if (eq system.kind "subtrait")}}selected{{/if}}>{{localize "HRPG.Subtrait"}}</option>
        </select>
      </label>
      <label>{{localize "HRPG.ParentTrait"}} <input name="system.parentTrait" type="text" value="{{system.parentTrait}}"></label>
      <label>HK-Kit ID <input name="system.sourceId" type="text" value="{{system.sourceId}}"></label>
    {{/if}}
    {{#if (eq item.type "path")}}
      <label>{{localize "HRPG.Rank"}}
        <select name="system.rank">
          <option value="1" {{#if (eq system.rank 1)}}selected{{/if}}>1</option>
          <option value="2" {{#if (eq system.rank 2)}}selected{{/if}}>2</option>
          <option value="3" {{#if (eq system.rank 3)}}selected{{/if}}>3</option>
        </select>
      </label>
      <label>{{localize "HRPG.PathCategory"}}
        <select name="system.category"><option value="martial" {{#if (eq system.category "martial")}}selected{{/if}}>{{localize "HRPG.PathMartial"}}</option><option value="mystic" {{#if (eq system.category "mystic")}}selected{{/if}}>{{localize "HRPG.PathMystic"}}</option></select>
      </label>
    {{/if}}
    {{#if (eq item.type "skill")}}
      <label>{{localize "HRPG.Rank"}} <input name="system.rank" type="number" min="0" value="{{system.rank}}"></label>
      <label>{{localize "HRPG.Mastery"}} <input name="system.mastery" type="text" value="{{system.mastery}}"></label>
    {{/if}}
    {{#if (eq item.type "weapon")}}<label>{{localize "HRPG.Damage"}} <input name="system.damage" type="number" value="{{system.damage}}"></label>{{/if}}
    {{#if (eq item.type "armor")}}<label>{{localize "HRPG.Protection"}} <input name="system.protection" type="number" value="{{system.protection}}"></label>{{/if}}
    {{#if system.attribute}}<label>{{localize "HRPG.BonusDice"}} <input name="system.bonusDice" type="number" value="{{system.bonusDice}}"></label>{{/if}}
  </section>
  {{#if (eq item.type "trait")}}
    <fieldset class="modifier-grid">
      <legend>{{localize "HRPG.TraitModifiers"}}</legend>
      <label>{{localize "HRPG.AttributePower"}} <input name="system.modifiers.power" type="number" step="0.5" value="{{system.modifiers.power}}"></label>
      <label>{{localize "HRPG.AttributeInsight"}} <input name="system.modifiers.insight" type="number" step="0.5" value="{{system.modifiers.insight}}"></label>
      <label>{{localize "HRPG.AttributeShell"}} <input name="system.modifiers.shell" type="number" step="0.5" value="{{system.modifiers.shell}}"></label>
      <label>{{localize "HRPG.AttributeGrace"}} <input name="system.modifiers.grace" type="number" step="0.5" value="{{system.modifiers.grace}}"></label>
      <label>{{localize "HRPG.ResourceHeart"}} <input name="system.modifiers.heart" type="number" step="0.5" value="{{system.modifiers.heart}}"></label>
      <label>{{localize "HRPG.ResourceStamina"}} <input name="system.modifiers.stamina" type="number" step="0.5" value="{{system.modifiers.stamina}}"></label>
      <label>{{localize "HRPG.ResourceSoul"}} <input name="system.modifiers.soul" type="number" step="0.5" value="{{system.modifiers.soul}}"></label>
      <label>{{localize "HRPG.Speed"}} <input name="system.modifiers.speed" type="number" step="0.5" value="{{system.modifiers.speed}}"></label>
      <label>{{localize "HRPG.Hunger"}} <input name="system.modifiers.hunger" type="number" step="0.5" value="{{system.modifiers.hunger}}"></label>
      <label>{{localize "HRPG.Appeal"}} <input name="system.modifiers.appeal" type="number" step="0.5" value="{{system.modifiers.appeal}}"></label>
      <label>{{localize "HRPG.Dread"}} <input name="system.modifiers.dread" type="number" step="0.5" value="{{system.modifiers.dread}}"></label>
      <label>{{localize "HRPG.Marks"}} <input name="system.modifiers.marks" type="number" step="0.5" value="{{system.modifiers.marks}}"></label>
      <label>{{localize "HRPG.Load"}} <input name="system.modifiers.load" type="number" step="0.5" value="{{system.modifiers.load}}"></label>
    </fieldset>
    {{#if system.costLabel}}<p class="trait-cost"><strong>{{localize "HRPG.TraitCost"}}:</strong> {{system.costLabel}}</p>{{/if}}
    {{#if system.rules.length}}<section class="trait-rules"><h2>{{localize "HRPG.TraitRules"}}</h2><ul>{{#each system.rules as |rule|}}<li>{{rule}}</li>{{/each}}</ul></section>{{/if}}
  {{/if}}
  {{#if (eq item.type "path")}}
    <section class="path-overview">
      <h2>{{localize "HRPG.PathDescription"}}</h2>
      <textarea name="system.description" placeholder="{{localize 'HRPG.PathDescriptionHint'}}">{{system.description}}</textarea>
    </section>
    <section class="path-ranks">
      <h2>{{localize "HRPG.PathRanks"}}</h2>
      {{#each system.ranks as |rank|}}
        <article class="path-rank {{#if (lte rank.rank ../system.rank)}}unlocked{{/if}}">
          <h3>{{localize "HRPG.Rank"}} {{rank.rank}} — {{rank.title}}</h3>
          <div class="path-abilities">{{#each rank.abilities as |ability|}}<strong>{{ability}}</strong>{{/each}}</div>
          <p>{{rank.text}}</p>
        </article>
      {{/each}}
    </section>
  {{/if}}
  {{#unless (eq item.type "path")}}{{editor system.description target="system.description" button=true owner=owner editable=editable}}{{/unless}}
</form>
