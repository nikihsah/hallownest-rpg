<form class="{{cssClass}}" autocomplete="off">
  {{#if (eq item.type "trait")}}
    <article class="trait-readonly">
      <header class="trait-readonly-header">
        <img class="profile-img" src="{{item.img}}" title="{{item.name}}">
        <div>
          <div class="trait-kicker">
            <span>{{#if (eq system.kind "subtrait")}}{{localize "HRPG.Subtrait"}}{{else}}{{localize "HRPG.Trait"}}{{/if}}</span>
            {{#if traitCategoryLabel}}<span>{{localize traitCategoryLabel}}</span>{{/if}}
            {{#unless system.active}}<span>{{localize "HRPG.TraitInactive"}}</span>{{/unless}}
          </div>
          <h1>{{item.name}}</h1>
          {{#if system.costLabel}}<p class="trait-cost"><strong>{{localize "HRPG.TraitCost"}}:</strong> {{system.costLabel}}</p>{{/if}}
          {{#if (eq system.kind "subtrait")}}<p class="trait-parent">{{localize "HRPG.ParentTrait"}}: {{system.parentTrait}}</p>{{/if}}
        </div>
      </header>

      {{#if system.description}}
        <section class="trait-description">
          <h2>{{localize "HRPG.Biography"}}</h2>
          <p>{{system.description}}</p>
        </section>
      {{/if}}

      {{#if traitModifierRows.length}}
        <section class="trait-effect-panel">
          <h2>{{localize "HRPG.TraitModifiers"}}</h2>
          <div class="trait-modifier-pills">
            {{#each traitModifierRows as |modifier|}}
              <span class="{{#if modifier.positive}}positive{{else}}negative{{/if}}">{{localize modifier.label}} {{modifier.signed}}</span>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{#if traitQualityEditable}}
        <section class="trait-effect-panel trait-quality-panel">
          <h2>{{localize "HRPG.WeaponQuality"}}</h2>
          <p>{{localize "HRPG.WeaponQualityHint"}}</p>
          <label>{{localize "HRPG.Quality"}}
            <span><input name="system.quality.value" type="number" min="-1" value="{{traitQualityValue}}"><b>/</b><input name="system.quality.max" type="number" min="0" value="{{traitQualityMax}}"></span>
          </label>
          {{#if itemModificationOptions.length}}
            <label>{{localize "HRPG.ItemModification"}}
              <select name="system.modification">
                <option value="">{{localize "HRPG.NoModification"}}</option>
                {{#each itemModificationOptions as |modification|}}<option value="{{modification.key}}" {{#if modification.selected}}selected{{/if}}>{{modification.name}}</option>{{/each}}
              </select>
            </label>
          {{/if}}
          {{#if selectedItemModification}}
            <div class="trait-modification-description">
              <strong>{{selectedItemModification.name}}</strong>
              <p>{{selectedItemModification.description}}</p>
            </div>
          {{/if}}
        </section>
      {{/if}}

      {{#if fluidVialEffectEditable}}
        <section class="trait-effect-panel trait-fluid-panel">
          <h2>{{localize "HRPG.FluidVialEffect"}}</h2>
          <p>{{localize "HRPG.FluidVialEffectHint"}}</p>
          <label>{{localize "HRPG.FluidVialEffect"}}
            <select name="system.vialEffect.sourceId" data-vial-effect-select>
              <option value="">{{localize "HRPG.ChooseVialEffect"}}</option>
              {{#each fluidVialEffectOptions as |effect|}}<option value="{{effect.sourceId}}" {{#if effect.selected}}selected{{/if}}>{{effect.label}}</option>{{/each}}
            </select>
          </label>
          {{#if selectedFluidVialEffect}}
            <div class="trait-fluid-description">
              <strong>{{selectedFluidVialEffect.name}}</strong>
              <small>{{selectedFluidVialEffect.rarity}}{{#if selectedFluidVialEffect.hungerCost}} · +{{selectedFluidVialEffect.hungerCost}} {{localize "HRPG.Hunger"}}{{/if}}</small>
              <p>{{selectedFluidVialEffect.description}}</p>
            </div>
          {{/if}}
        </section>
      {{/if}}

      {{#if system.rules.length}}
        <section class="trait-effect-panel">
          <h2>{{localize "HRPG.TraitRules"}}</h2>
          <ul class="trait-rule-list">{{#each system.rules as |rule|}}<li>{{rule}}</li>{{/each}}</ul>
        </section>
      {{/if}}
    </article>
  {{else}}
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}">
    <div class="header-fields"><input class="name" name="name" type="text" value="{{item.name}}"></div>
  </header>
  {{#unless (eq item.type "path")}}
    <section class="item-description-editor">
      <h2>{{localize "HRPG.ItemDescription"}}</h2>
      <textarea name="system.description" placeholder="{{localize 'HRPG.ItemDescriptionHint'}}">{{system.description}}</textarea>
    </section>
  {{/unless}}
  <section class="item-properties">
    {{#unless (eq item.type "path")}}<label>{{localize "HRPG.Quantity"}} <input name="system.quantity" type="number" value="{{system.quantity}}"></label>{{/unless}}
    {{#unless (eq item.type "path")}}<label>{{localize "HRPG.Weight"}} <input name="system.weight" type="number" step="0.1" value="{{system.weight}}"></label>{{/unless}}
    {{#unless (eq item.type "path")}}<label>{{localize "HRPG.Price"}} <input name="system.price" type="text" value="{{system.price}}"></label>{{/unless}}
    {{#unless (eq item.type "path")}}<label>{{localize "HRPG.Subtype"}} <input name="system.subtype" type="text" value="{{system.subtype}}"></label>{{/unless}}
    {{#unless (eq item.type "path")}}{{#if system.equipped}}<label class="item-equipped-editor">{{localize "HRPG.Equipped"}} <input name="system.equipped" type="checkbox" checked></label>{{else}}<label class="item-equipped-editor">{{localize "HRPG.Equipped"}} <input name="system.equipped" type="checkbox"></label>{{/if}}{{/unless}}
    {{#if itemModificationOptions.length}}
      <label>{{localize "HRPG.ItemModification"}}
        <select name="system.modification">
          <option value="">{{localize "HRPG.NoModification"}}</option>
          {{#each itemModificationOptions as |modification|}}<option value="{{modification.key}}" {{#if modification.selected}}selected{{/if}}>{{modification.name}}</option>{{/each}}
        </select>
      </label>
    {{/if}}
    {{#if (eq item.type "path")}}
      <label>{{localize "HRPG.Rank"}}
        <select name="system.rank">{{selectOptions pathRankOptions selected=system.rank}}</select>
      </label>
      <label>{{localize "HRPG.PathCategory"}}
        <select name="system.category"><option value="martial" {{#if (eq system.category "martial")}}selected{{/if}}>{{localize "HRPG.PathMartial"}}</option><option value="mystic" {{#if (eq system.category "mystic")}}selected{{/if}}>{{localize "HRPG.PathMystic"}}</option></select>
      </label>
    {{/if}}
    {{#if (eq item.type "skill")}}
      <label>{{localize "HRPG.Rank"}}
        <select name="system.rank">{{selectOptions skillRankOptions selected=system.rank}}</select>
      </label>
      <label>{{localize "HRPG.Mastery"}}
        <select name="system.mastery">
          <option value="">{{localize "HRPG.NoMastery"}}</option>
          {{#each skillMasteryOptions as |label value|}}<option value="{{value}}" {{#if (eq ../system.mastery value)}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </label>
    {{/if}}
    {{#if (eq item.type "art")}}
      <label class="item-equipped-editor">{{localize "HRPG.Prepared"}} <input name="system.prepared" type="checkbox" {{#if system.prepared}}checked{{/if}}></label>
      <label>{{localize "HRPG.TechniqueTypeLabel"}}
        <select name="system.techniqueType">{{selectOptions techniqueTypeOptions selected=system.techniqueType localize=true}}</select>
      </label>
      <label>{{localize "HRPG.PathFamily"}} <input name="system.pathName" type="text" value="{{system.pathName}}"></label>
      <label>{{localize "HRPG.Requirements"}} <input name="system.requirementLabel" type="text" value="{{system.requirementLabel}}"></label>
      <label>{{localize "HRPG.Cost"}} <input name="system.cost.raw" type="text" value="{{system.cost.raw}}"></label>
      <label>{{localize "HRPG.ResourceStamina"}} <input name="system.cost.stamina" type="number" min="0" value="{{system.cost.stamina}}"></label>
      <label>{{localize "HRPG.ResourceSoul"}} <input name="system.cost.soul" type="number" min="0" value="{{system.cost.soul}}"></label>
      <label>{{localize "HRPG.ResourceEssence"}} <input name="system.cost.essence" type="number" min="0" value="{{system.cost.essence}}"></label>
    {{/if}}
    {{#if (eq item.type "spell")}}
      <label class="item-equipped-editor">{{localize "HRPG.Prepared"}} <input name="system.prepared" type="checkbox" {{#if system.prepared}}checked{{/if}}></label>
      <label>{{localize "HRPG.PathMystic"}} <input name="system.pathName" type="text" value="{{system.pathName}}"></label>
      <label>{{localize "HRPG.Requirements"}} <input name="system.requirementLabel" type="text" value="{{system.requirementLabel}}"></label>
      <label>{{localize "HRPG.Cost"}} <input name="system.cost.raw" type="text" value="{{system.cost.raw}}"></label>
      <label>{{localize "HRPG.SpellDifficulty"}} <input name="system.cost.difficulty" type="number" min="0" value="{{system.cost.difficulty}}"></label>
      <label>{{localize "HRPG.ResourceSoul"}} <input name="system.cost.soul" type="number" min="0" value="{{system.cost.soul}}"></label>
      <label>{{localize "HRPG.ResourceStamina"}} <input name="system.cost.stamina" type="number" min="0" value="{{system.cost.stamina}}"></label>
      <label>{{localize "HRPG.ResourceEssence"}} <input name="system.cost.essence" type="number" min="0" value="{{system.cost.essence}}"></label>
      <label>{{localize "HRPG.Range"}} <input name="system.range" type="text" value="{{system.range}}"></label>
      <label>{{localize "HRPG.Duration"}} <input name="system.duration" type="text" value="{{system.duration}}"></label>
    {{/if}}
    {{#if (eq item.type "weapon")}}
      <label>{{localize "HRPG.ItemType"}} <input name="system.itemType" type="text" value="{{system.itemType}}"></label>
      <label>{{localize "HRPG.Damage"}} <input name="system.damage" type="text" value="{{system.damage}}"></label>
      <label>{{localize "HRPG.Range"}} <input name="system.range" type="text" value="{{system.range}}"></label>
      <label>{{localize "HRPG.Grip"}} <input name="system.grip" type="text" value="{{system.grip}}"></label>
      <label>{{localize "HRPG.Quality"}} <span><input name="system.quality.value" type="number" min="-1" value="{{system.quality.value}}"><b>/</b><input name="system.quality.max" type="number" min="0" value="{{system.quality.max}}"></span></label>
    {{/if}}
    {{#if (eq item.type "armor")}}
      <label>{{localize "HRPG.Protection"}} <input name="system.protection" type="number" value="{{system.protection}}"></label>
      <label>{{localize "HRPG.DamageReduction"}} <input name="system.damageReduction" type="number" value="{{system.damageReduction}}"></label>
      <label>{{localize "HRPG.Durability"}} <input name="system.durability" type="number" value="{{system.durability}}"></label>
      <label>{{localize "HRPG.Quality"}} <span><input name="system.quality.value" type="number" min="-1" value="{{system.quality.value}}"><b>/</b><input name="system.quality.max" type="number" min="0" value="{{system.quality.max}}"></span></label>
    {{/if}}
    {{#if (eq item.type "charm")}}
      <label>{{localize "HRPG.Notches"}} <input name="system.notches" type="number" min="0" value="{{system.notches}}"></label>
      <label>{{localize "HRPG.Rarity"}} <input name="system.rarity" type="text" value="{{system.rarity}}"></label>
    {{/if}}
    {{#if (eq item.type "consumable")}}
      <label>{{localize "HRPG.Uses"}} <span><input name="system.uses.value" type="number" min="0" value="{{system.uses.value}}"><b>/</b><input name="system.uses.max" type="number" min="0" value="{{system.uses.max}}"></span></label>
      <label>{{localize "HRPG.Potency"}} <input name="system.potency" type="text" value="{{system.potency}}"></label>
      <label>{{localize "HRPG.Satiety"}} <input name="system.satiety" type="text" value="{{system.satiety}}"></label>
      <label>{{localize "HRPG.Rarity"}} <input name="system.rarity" type="text" value="{{system.rarity}}"></label>
      <label>{{localize "HRPG.Reusable"}} <input name="system.reusable" type="text" value="{{system.reusable}}"></label>
    {{/if}}
    {{#if system.attribute}}<label>{{localize "HRPG.BonusDice"}} <input name="system.bonusDice" type="number" value="{{system.bonusDice}}"></label>{{/if}}
  </section>
  {{#if (eq item.type "path")}}
    <section class="path-overview">
      <h2>{{localize "HRPG.PathDescription"}}</h2>
      <textarea name="system.description" placeholder="{{localize 'HRPG.PathDescriptionHint'}}">{{system.description}}</textarea>
    </section>
    <section class="path-ranks">
      <h2>{{localize "HRPG.PathRanks"}}</h2>
      {{#each system.ranks as |rank|}}
        <article class="path-rank {{#if (lte rank.rank ../system.rank)}}unlocked{{/if}}">
          <h3>{{localize "HRPG.Rank"}} {{rank.rank}} — {{rank.title}}</h3>
          <div class="path-abilities">{{#each rank.abilities as |ability|}}<strong>{{ability}}</strong>{{/each}}</div>
          <p>{{rank.text}}</p>
        </article>
      {{/each}}
    </section>
  {{/if}}
  {{#if (eq item.type "skill")}}
    <section class="skill-editor">
      <h2>{{localize "HRPG.SkillList"}}</h2>
      <p>{{localize "HRPG.SkillListHint"}}</p>
      {{#each skillRows as |row|}}
        <label>{{localize "HRPG.SkillName"}}
          <input name="system.skills.{{row.key}}.name" type="text" value="{{row.name}}" placeholder="{{localize 'HRPG.SkillNameHint'}}">
        </label>
      {{/each}}
    </section>
  {{/if}}
  {{#if isTechniqueItem}}
    <section class="technique-effect-text">
      <h2>{{localize "HRPG.TechniqueEffect"}}</h2>
      <textarea name="system.effectText" placeholder="{{localize 'HRPG.TechniqueEffectHint'}}">{{system.effectText}}</textarea>
    </section>
  {{/if}}
  {{#unless (eq item.type "path")}}
    <section class="item-attachments">
      <h2>{{localize "HRPG.Attachments"}}</h2>
      {{#each attachmentRows as |attachment|}}
        <label>{{localize "HRPG.Attachment"}}
          <span><input name="system.attachments.{{attachment.key}}" type="text" value="{{attachment.value}}"><button type="button" data-attachment-picker="{{attachment.key}}">{{localize "HRPG.ChooseFile"}}</button></span>
        </label>
      {{/each}}
    </section>
  {{/unless}}
  {{#if selectedItemModification}}
    <section class="item-modification-description">
      <h2>{{localize "HRPG.ItemModification"}}: {{selectedItemModification.name}}</h2>
      <p>{{selectedItemModification.description}}</p>
    </section>
  {{/if}}
  {{#if system.rawText}}<section class="item-raw-text"><h2>{{localize "HRPG.ItemRawText"}}</h2><p>{{system.rawText}}</p></section>{{/if}}
  {{/if}}
</form>
